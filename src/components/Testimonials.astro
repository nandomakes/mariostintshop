---
import { TESTIMONIALS } from '../consts';

// Duplicate the set so the carousel can loop seamlessly: when the auto-play
// reaches the second copy it jumps back (instantly) to the first.
const slides = [...TESTIMONIALS, ...TESTIMONIALS];
---

<section id="testimonials" class="hex-bg bg-paper">
  <div class="mx-auto max-w-6xl px-5 py-20 md:py-24">
    <div class="text-center">
      <p class="reveal kicker text-accentDk">Testimonials</p>
      <h2 class="reveal headline mx-auto mt-3 max-w-3xl text-[clamp(1.4rem,2.8vw,2.2rem)] text-ink">
        Real reviews from real people
      </h2>
    </div>

    <div
      id="testimonial-track"
      class="no-scrollbar mt-12 flex gap-6 overflow-x-auto"
      aria-label="Customer reviews carousel"
    >
      {
        slides.map((t, i) => (
          <figure
            class="w-full shrink-0 bg-mint sm:w-[calc((100%-1.5rem)/2)] lg:w-[calc((100%-3rem)/3)]"
            aria-hidden={i >= TESTIMONIALS.length ? 'true' : undefined}
          >
            <!-- Evidence shot: the customer's finished vehicle -->
            <img
              src={t.photo.src}
              alt={t.photo.alt}
              width="800"
              height="500"
              loading="lazy"
              class="aspect-[8/5] w-full object-cover"
            />
            <div class="relative p-8">
              <div class="flex gap-1 text-accentDk" aria-label="5 out of 5 stars">
                {Array.from({ length: 5 }).map(() => (
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                    <path d="M12 2l2.9 6.3 6.9.8-5.1 4.7 1.4 6.8L12 17.2l-6.1 3.4 1.4-6.8L2.2 9.1l6.9-.8L12 2z" />
                  </svg>
                ))}
              </div>
              <blockquote class="mt-4 text-[15px] leading-relaxed text-char">“{t.quote}”</blockquote>
              <hr class="my-5 border-accentDk/15" />
              <figcaption>
                <p class="headline text-base tracking-[0.06em] text-ink">{t.author}</p>
              </figcaption>
              <span class="pointer-events-none absolute bottom-6 right-7 text-accentDk/30" aria-hidden="true">
                <svg width="38" height="38" viewBox="0 0 24 24" fill="currentColor"><path d="M10 7H6a3 3 0 0 0-3 3v4a3 3 0 0 0 3 3h2a3 3 0 0 0 3-3v-7a4 4 0 0 0-1-2.6L8.6 3 7 4.4 8.4 6A4 4 0 0 1 10 7Zm11 0h-4a3 3 0 0 0-3 3v4a3 3 0 0 0 3 3h2a3 3 0 0 0 3-3v-7a4 4 0 0 0-1-2.6L19.6 3 18 4.4 19.4 6A4 4 0 0 1 21 7Z" /></svg>
              </span>
            </div>
          </figure>
        ))
      }
    </div>
  </div>
</section>

<script>
  // Auto-advance one card every 4s; jumps back seamlessly thanks to the
  // duplicated slide set. Pauses on hover/touch and under reduced motion.
  const track = document.getElementById('testimonial-track');
  if (track) {
    const slides = Array.from(track.children) as HTMLElement[];
    const half = slides.length / 2;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let idx = 0;
    let paused = false;

    const go = (i: number, smooth: boolean) => {
      track.scrollTo({
        left: slides[i].offsetLeft - slides[0].offsetLeft,
        behavior: smooth ? 'smooth' : 'auto',
      });
    };

    track.addEventListener('mouseenter', () => (paused = true));
    track.addEventListener('mouseleave', () => (paused = false));
    track.addEventListener('touchstart', () => (paused = true), { passive: true });
    track.addEventListener('touchend', () => setTimeout(() => (paused = false), 4000), { passive: true });

    if (!reduce) {
      setInterval(() => {
        if (paused || document.hidden) return;
        idx += 1;
        go(idx, true);
        if (idx >= half) {
          // After the smooth scroll lands on the duplicate, snap back to the
          // matching original card without animation.
          const back = idx - half;
          setTimeout(() => {
            go(back, false);
            idx = back;
          }, 700);
        }
      }, 4000);
    }
  }
</script>
