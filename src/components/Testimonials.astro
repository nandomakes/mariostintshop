---
import { TESTIMONIALS } from '../consts';
---

<section id="testimonios" class="bg-arena py-16 md:py-24" aria-label="Testimonios de pacientes">
  <div class="mx-auto grid max-w-5xl gap-8 px-5 text-center md:grid-cols-3">
    {
      TESTIMONIALS.map((t) => (
        <figure class="reveal">
          <blockquote class="font-display text-lg leading-snug">"{t.quote}"</blockquote>
          <figcaption class="mt-3 text-xs uppercase tracking-[0.2em] text-olivaDk">
            {t.author} · {t.detail}
          </figcaption>
        </figure>
      ))
    }
  </div>
</section>
