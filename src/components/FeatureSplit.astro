---
// Reusable text + image split. Image is absolutely positioned so it never
// dictates the row height.
interface Props {
  kicker?: string;
  title: string;
  lead?: string;
  paragraphs?: string[];
  imageSrc: string;
  imageAlt: string;
  imageW?: number;
  imageH?: number;
  reverse?: boolean; // image on the left instead of the right
  cta?: { href: string; label: string };
}

const {
  kicker,
  title,
  lead,
  paragraphs = [],
  imageSrc,
  imageAlt,
  imageW = 1400,
  imageH = 1000,
  reverse = false,
  cta,
} = Astro.props;

const textOrder = reverse ? 'md:order-2' : 'md:order-1';
const imgOrder = reverse ? 'md:order-1' : 'md:order-2';
---

<section class="grid bg-paper md:min-h-[540px] md:grid-cols-2">
  <div class={`reveal order-1 flex flex-col justify-center px-6 py-16 md:px-14 md:py-20 ${textOrder}`}>
    {kicker && <span class="kicker mb-4 text-accentDk">{kicker}</span>}
    <h2 class="headline text-[clamp(1.8rem,3.5vw,2.5rem)] text-ink" set:html={title} />
    {lead && <p class="mt-5 max-w-[56ch] text-lg font-semibold leading-snug text-ink">{lead}</p>}
    {paragraphs.map((p) => <p class="mt-4 max-w-[62ch] leading-relaxed text-char">{p}</p>)}
    {
      cta && (
        <a
          href={cta.href}
          class="pressable sticker mt-8 self-start bg-accent px-8 py-3.5 text-xs font-bold uppercase tracking-[0.12em] text-ink transition-[background-color,transform] duration-200 hover:-translate-y-0.5 hover:bg-accentDk"
        >
          {cta.label}
        </a>
      )
    }
  </div>
  <div class={`zoom-parent relative order-2 min-h-[320px] overflow-hidden ${imgOrder}`}>
    <img
      src={imageSrc}
      alt={imageAlt}
      width={imageW}
      height={imageH}
      loading="lazy"
      class="zoom-img absolute inset-0 h-full w-full object-cover"
    />
  </div>
</section>
