---
import { INSTAGRAM } from '../consts';
import { getInstagramFeed } from '../lib/instagram';

// Pulls the shop's latest Instagram posts at build time (falls back to the
// curated images in consts.ts when no INSTAGRAM_TOKEN is configured).
const posts = await getInstagramFeed(8);
---

<section id="gallery" class="bg-ink">
  <div class="mx-auto max-w-6xl px-5 py-20 md:py-24">
    <div class="text-center">
      <p class="reveal kicker text-accent">Our instagram</p>
      <h2 class="reveal headline mx-auto mt-3 max-w-3xl text-[clamp(1.4rem,2.8vw,2.2rem)] text-paper">
        Where craftsmanship meets flawless finish
      </h2>
    </div>

    <div class="relative mt-12">
      <div
        id="gallery-track"
        class="no-scrollbar flex snap-x snap-mandatory gap-4 overflow-x-auto scroll-smooth pb-2"
      >
        {
          posts.map((img) => (
            <a
              href={img.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group relative w-[260px] shrink-0 snap-start overflow-hidden sm:w-[300px]"
            >
              <img
                src={img.src}
                alt={img.alt}
                width="600"
                height="600"
                loading="lazy"
                class="aspect-square w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.05]"
              />
              <span
                class="pointer-events-none absolute inset-0 flex items-end bg-gradient-to-t from-ink/70 via-transparent to-transparent p-4 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
                aria-hidden="true"
              >
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.5" cy="6.5" r="1.2" fill="#fff" stroke="none" />
                </svg>
              </span>
            </a>
          ))
        }
      </div>

      <!-- Slider arrows -->
      <button
        type="button"
        data-dir="prev"
        class="gallery-arrow pressable absolute -left-3 top-1/2 hidden h-12 w-12 -translate-y-1/2 items-center justify-center bg-accent text-ink shadow-lg shadow-accent/25 transition-[opacity,background-color] duration-200 hover:bg-accentDk disabled:pointer-events-none disabled:opacity-0 md:flex"
        aria-label="Previous photos"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 6l-6 6 6 6" /></svg>
      </button>
      <button
        type="button"
        data-dir="next"
        class="gallery-arrow pressable absolute -right-3 top-1/2 hidden h-12 w-12 -translate-y-1/2 items-center justify-center bg-accent text-ink shadow-lg shadow-accent/25 transition-[opacity,background-color] duration-200 hover:bg-accentDk disabled:pointer-events-none disabled:opacity-0 md:flex"
        aria-label="Next photos"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 6l6 6-6 6" /></svg>
      </button>
    </div>

    <p class="reveal mt-8 text-center text-sm text-smoke">
      See our latest tint, PPF, and ceramic work —
      <a
        href={INSTAGRAM.url}
        target="_blank"
        rel="noopener noreferrer"
        class="font-bold text-accent underline underline-offset-4 transition-colors hover:text-accentDk"
      >
        {INSTAGRAM.handle}
      </a>
    </p>
  </div>
</section>

<script>
  const track = document.getElementById('gallery-track');
  if (track) {
    const arrows = Array.from(
      document.querySelectorAll<HTMLButtonElement>('.gallery-arrow')
    );
    const EPS = 4;

    // Scroll amount = as many whole cards as are visible (min one card).
    const step = () => {
      const card = track.querySelector<HTMLElement>('a');
      const cardW = card ? card.offsetWidth + 16 : 300;
      return Math.max(cardW, Math.floor(track.clientWidth / cardW) * cardW);
    };
    const maxScroll = () => track.scrollWidth - track.clientWidth;

    // Dim/disable arrows at the track edges so the control state is honest.
    const sync = () => {
      const max = maxScroll();
      const prev = arrows.find((a) => a.dataset.dir === 'prev');
      const next = arrows.find((a) => a.dataset.dir === 'next');
      if (prev) prev.disabled = track.scrollLeft <= EPS;
      if (next) next.disabled = track.scrollLeft >= max - EPS || max <= EPS;
    };

    arrows.forEach((btn) =>
      btn.addEventListener('click', () => {
        const dir = btn.dataset.dir === 'next' ? 1 : -1;
        track.scrollBy({ left: dir * step(), behavior: 'smooth' });
      })
    );

    track.addEventListener('scroll', sync, { passive: true });
    window.addEventListener('resize', sync);
    // Wait a frame so layout (and lazy images) settle before first measure.
    requestAnimationFrame(sync);
  }
</script>
