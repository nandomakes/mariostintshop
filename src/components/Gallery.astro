---
import { GALLERY, INSTAGRAM } from '../consts';
---

<section id="gallery" class="bg-ink">
  <div class="mx-auto max-w-6xl px-5 py-20 md:py-24">
    <div class="text-center">
      <p class="reveal kicker text-accent">Our instagram</p>
      <h2 class="reveal headline mx-auto mt-3 max-w-3xl text-[clamp(1.4rem,2.8vw,2.2rem)] text-paper">
        Where craftsmanship meets flawless finish
      </h2>
    </div>

    <div class="relative mt-12">
      <div
        id="gallery-track"
        class="no-scrollbar flex snap-x snap-mandatory gap-4 overflow-x-auto pb-2"
      >
        {
          GALLERY.map((img) => (
            <a
              href={INSTAGRAM.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group w-[260px] shrink-0 snap-start overflow-hidden sm:w-[300px]"
            >
              <img
                src={img.src}
                alt={img.alt}
                width="600"
                height="600"
                loading="lazy"
                class="aspect-square w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.05]"
              />
            </a>
          ))
        }
      </div>

      <!-- Slider arrows -->
      <button
        type="button"
        data-dir="prev"
        class="gallery-arrow pressable absolute -left-3 top-1/2 hidden h-12 w-12 -translate-y-1/2 items-center justify-center bg-accent text-ink shadow-lg shadow-accent/25 transition-colors duration-200 hover:bg-accentDk md:flex"
        aria-label="Previous photos"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 6l-6 6 6 6" /></svg>
      </button>
      <button
        type="button"
        data-dir="next"
        class="gallery-arrow pressable absolute -right-3 top-1/2 hidden h-12 w-12 -translate-y-1/2 items-center justify-center bg-accent text-ink shadow-lg shadow-accent/25 transition-colors duration-200 hover:bg-accentDk md:flex"
        aria-label="Next photos"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 6l6 6-6 6" /></svg>
      </button>
    </div>

    <p class="reveal mt-8 text-center text-sm text-smoke">
      See our latest tint, PPF, and ceramic work —
      <a
        href={INSTAGRAM.url}
        target="_blank"
        rel="noopener noreferrer"
        class="font-bold text-accent underline underline-offset-4 transition-colors hover:text-accentDk"
      >
        {INSTAGRAM.handle}
      </a>
    </p>
  </div>
</section>

<script>
  const track = document.getElementById('gallery-track');
  if (track) {
    document.querySelectorAll<HTMLButtonElement>('.gallery-arrow').forEach((btn) => {
      btn.addEventListener('click', () => {
        const card = track.querySelector<HTMLElement>('a');
        const cardW = card ? card.offsetWidth + 16 : 300;
        // Advance a full "page" of visible cards, minimum one card.
        const page = Math.max(cardW, Math.floor(track.clientWidth / cardW) * cardW);
        const max = track.scrollWidth - track.clientWidth;
        const next = btn.dataset.dir === 'next';

        if (next && track.scrollLeft >= max - 4) {
          // Reached the end → loop back to the start.
          track.scrollTo({ left: 0, behavior: 'smooth' });
        } else if (!next && track.scrollLeft <= 4) {
          // At the start → jump to the end.
          track.scrollTo({ left: max, behavior: 'smooth' });
        } else {
          track.scrollBy({ left: next ? page : -page, behavior: 'smooth' });
        }
      });
    });
  }
</script>
