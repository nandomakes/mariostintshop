---
import { INSTAGRAM } from '../consts';
import { getInstagramFeed } from '../lib/instagram';

// Pulls the shop's latest Instagram posts at build time (falls back to the
// curated images in consts.ts when no INSTAGRAM_TOKEN is configured).
const posts = await getInstagramFeed(8);
---

<section id="gallery" class="bg-ink">
  <div class="mx-auto max-w-6xl px-5 py-20 md:py-24">
    <div class="text-center">
      <p class="reveal kicker text-accent">Our instagram</p>
      <h2 class="reveal headline mx-auto mt-3 max-w-3xl text-[clamp(1.4rem,2.8vw,2.2rem)] text-paper">
        Where craftsmanship meets flawless finish
      </h2>
    </div>

    <div class="relative mt-12">
      <div
        id="gallery-track"
        class="no-scrollbar flex gap-4 overflow-x-auto scroll-smooth pb-2"
        style="overscroll-behavior-x: contain; -webkit-overflow-scrolling: touch; scroll-behavior: smooth;"
      >
        {
          posts.map((img) => (
            <a
              href={img.href}
              target="_blank"
              rel="noopener noreferrer"
              class="group relative w-[260px] shrink-0 overflow-hidden sm:w-[300px]"
            >
              <img
                src={img.src}
                alt={img.alt}
                width="600"
                height="600"
                loading="lazy"
                decoding="async"
                draggable="false"
                class="aspect-square w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.05]"
              />
              <span
                class="pointer-events-none absolute inset-0 flex items-end bg-gradient-to-t from-ink/70 via-transparent to-transparent p-4 opacity-0 transition-opacity duration-300 group-hover:opacity-100"
                aria-hidden="true"
              >
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" />
                  <circle cx="12" cy="12" r="4" />
                  <circle cx="17.5" cy="6.5" r="1.2" fill="#fff" stroke="none" />
                </svg>
              </span>
            </a>
          ))
        }
      </div>

      <!-- Slider arrows -->
      <button
        type="button"
        data-dir="prev"
        class="gallery-arrow pressable absolute -left-3 top-1/2 hidden h-12 w-12 -translate-y-1/2 items-center justify-center bg-accent text-ink shadow-lg shadow-accent/25 transition-[opacity,background-color] duration-200 hover:bg-accentDk disabled:pointer-events-none disabled:opacity-30 md:flex"
        aria-label="Previous photos"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 6l-6 6 6 6" /></svg>
      </button>
      <button
        type="button"
        data-dir="next"
        class="gallery-arrow pressable absolute -right-3 top-1/2 hidden h-12 w-12 -translate-y-1/2 items-center justify-center bg-accent text-ink shadow-lg shadow-accent/25 transition-[opacity,background-color] duration-200 hover:bg-accentDk disabled:pointer-events-none disabled:opacity-30 md:flex"
        aria-label="Next photos"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 6l6 6-6 6" /></svg>
      </button>
    </div>

    <p class="reveal mt-8 text-center text-sm text-smoke">
      See our latest tint, PPF, and ceramic work —
      <a
        href={INSTAGRAM.url}
        target="_blank"
        rel="noopener noreferrer"
        class="font-bold text-accent underline underline-offset-4 transition-colors hover:text-accentDk"
      >
        {INSTAGRAM.handle}
      </a>
    </p>
  </div>
</section>

<script>
  const track = document.getElementById('gallery-track');
  if (track) {
    const arrows = Array.from(
      document.querySelectorAll<HTMLButtonElement>('.gallery-arrow')
    );
    const EPS = 4;
    let resizeTimeout: number;

    // Advance three cards per click, so each press reveals a fresh set of three
    // images (plus the half-peek of the next, since ~3.5 fit in view).
    const step = () => {
      const card = track.querySelector<HTMLElement>('a');
      return (card ? card.offsetWidth + 16 : 300) * 3;
    };
    const maxScroll = () => track.scrollWidth - track.clientWidth;

    // Dim/disable arrows at the track edges so the control state is honest.
    const sync = () => {
      const max = maxScroll();
      const prev = arrows.find((a) => a.dataset.dir === 'prev');
      const next = arrows.find((a) => a.dataset.dir === 'next');
      if (prev) prev.disabled = track.scrollLeft <= EPS;
      if (next) next.disabled = track.scrollLeft >= max - EPS || max <= EPS;
    };

    arrows.forEach((btn) => {
      // Prevent the button from taking focus on press: a focused control that
      // then becomes `disabled` at a track edge makes the browser scroll the
      // page to the top ("the box jumps down"). Suppressing focus keeps the
      // page perfectly still while the strip slides.
      btn.addEventListener('pointerdown', (e) => e.preventDefault());
      btn.addEventListener('click', () => {
        const dir = btn.dataset.dir === 'next' ? 1 : -1;
        track.scrollBy({ left: dir * step(), behavior: 'smooth' });
        // Sync button states after scroll completes
        setTimeout(sync, 600);
      });
    });

    track.addEventListener('scroll', sync, { passive: true });

    // Debounced resize handler to avoid frequent recalculations
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimeout);
      resizeTimeout = window.setTimeout(sync, 150);
    }, { passive: true });

    // Wait a frame so layout (and lazy images) settle before first measure.
    requestAnimationFrame(() => {
      sync();
      // Re-sync after images load to account for lazy-loaded dimensions
      const images = track.querySelectorAll('img');
      let loadedCount = 0;
      images.forEach((img) => {
        if (img.complete) {
          loadedCount++;
        } else {
          img.addEventListener('load', () => {
            loadedCount++;
            if (loadedCount === images.length) sync();
          }, { once: true });
        }
      });
    });

    // Desktop drag-to-scroll: 1:1 with the pointer, no snap fighting back —
    // this is what makes the strip feel smooth instead of sticky.
    let dragging = false;
    let startX = 0;
    let startScroll = 0;
    let moved = false;
    let rafId: number;

    track.addEventListener('pointerdown', (e) => {
      if (e.pointerType !== 'mouse') return; // touch already scrolls natively
      dragging = true;
      moved = false;
      startX = e.clientX;
      startScroll = track.scrollLeft;
      track.style.cursor = 'grabbing';
      track.style.willChange = 'scroll-position';
    }, { passive: true });

    const handleMove = (e: PointerEvent) => {
      if (!dragging) return;
      const dx = e.clientX - startX;
      if (Math.abs(dx) > 4) moved = true;
      track.scrollLeft = startScroll - dx;
    };

    window.addEventListener('pointermove', (e) => {
      if (!dragging) return;
      if (rafId) cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(() => handleMove(e));
    }, { passive: true });

    window.addEventListener('pointerup', () => {
      if (rafId) cancelAnimationFrame(rafId);
      dragging = false;
      track.style.cursor = '';
      track.style.willChange = 'auto';
    }, { passive: true });

    // Swallow the click that ends a drag so links don't open accidentally.
    track.addEventListener('click', (e) => {
      if (moved) {
        e.preventDefault();
        e.stopPropagation();
        moved = false;
      }
    }, true);
  }
</script>
