---
import { PROGRAMS } from '../consts';
---

<section class="bg-oliva text-crema" aria-label="Programas destacados">
  <div
    class="mx-auto grid max-w-6xl divide-y divide-crema/25 text-center sm:grid-cols-3 sm:divide-x sm:divide-y-0"
  >
    {
      PROGRAMS.map((program) => (
        <a
          href="#servicios"
          class="group flex items-center justify-center px-4 py-8 transition-colors duration-300 ease-out hover:bg-olivaDk"
        >
          <p class="font-display text-lg leading-snug transition-transform duration-300 ease-out group-hover:-translate-y-0.5">
            {program}
          </p>
        </a>
      ))
    }
  </div>
</section>
