---
import { HERO, IMAGES } from '../consts';
import Ticker from './Ticker.astro';
---

<section
  id="home"
  class="relative flex min-h-[calc(100svh-72px)] flex-col overflow-hidden bg-ink md:min-h-[calc(100svh-116px)]"
>
  <!-- Full-bleed image with dark overlay for legibility -->
  <div class="absolute inset-0" aria-hidden="true">
    <img
      src={IMAGES.heroBg.src}
      alt=""
      width={IMAGES.heroBg.width}
      height={IMAGES.heroBg.height}
      fetchpriority="high"
      class="h-full w-full scale-150 object-contain object-center"
    />
    <div class="absolute inset-0 bg-black/45"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-ink/60 via-transparent to-ink"></div>
  </div>

  <div class="relative w-full flex-1 content-center px-4 py-10 text-left sm:px-5 sm:py-12 md:py-16">
    <div class="w-full max-w-2xl pl-8 sm:pl-12 md:pl-16">
      <p class="reveal kicker text-[clamp(1rem,3vw,1.35rem)] text-accent">{HERO.kicker}</p>

      <h1 class="reveal headline mt-3 text-[clamp(1.6rem,4.5vw,3.25rem)] text-paper md:mt-4">
        {HERO.line1}<br />{HERO.line2}
      </h1>

      <p class="reveal mt-5 max-w-[52ch] text-[clamp(0.9rem,2.5vw,1.125rem)] leading-relaxed text-smoke md:mt-6">
        {HERO.sub}
      </p>

      <div class="reveal mt-7 flex flex-col items-start gap-3 sm:flex-row md:mt-9">
        <a
          href="/#contact"
          class="pressable sticker bg-accent px-8 py-3.5 text-center text-xs font-bold uppercase tracking-[0.12em] text-ink transition-[background-color,transform] duration-200 hover:-translate-y-0.5 hover:bg-accentDk"
        >
          Get a Quote →
        </a>
      </div>
    </div>
  </div>

  <!-- Single ticker strip for the whole site -->
  <Ticker />
</section>
