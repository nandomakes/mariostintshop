---
interface Props {
  items: { q: string; a: string }[];
}
const { items } = Astro.props;
---

<section class="bg-paper">
  <div class="mx-auto max-w-3xl px-5 py-16 md:py-24">
    <p class="kicker mb-2 text-center text-accentDk">FAQ</p>
    <h2 class="headline mb-12 text-center text-[clamp(1.8rem,4vw,2.75rem)] text-ink">
      Common questions
    </h2>
    <div class="divide-y divide-sand border-y border-sand">
      {
        items.map((item) => (
          <details class="faq group">
            <summary class="faq-summary flex cursor-pointer list-none items-center justify-between gap-4 py-5 text-left text-lg font-bold text-ink marker:hidden [&::-webkit-details-marker]:hidden">
              {item.q}
              <span
                class="faq-icon grid h-6 w-6 shrink-0 place-items-center text-xl font-bold leading-none text-accentDk"
                aria-hidden="true"
              >
                +
              </span>
            </summary>
            <div class="faq-content">
              <p class="pb-6 leading-relaxed text-char">{item.a}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* The answer wrapper is clipped so it can be height-animated by the script. */
  .faq-content {
    overflow: hidden;
    will-change: height;
  }
  /* Plus → cross. Springy custom ease so it feels alive, not mechanical. */
  .faq-icon {
    transition: transform 300ms cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .faq[open] .faq-icon {
    transform: rotate(135deg);
  }
  .faq-summary {
    transition: color 200ms ease-out;
  }
  .faq-summary:hover {
    color: #0086d6;
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-icon {
      transition: none;
    }
  }
</style>

<script>
  // Emil-style animated <details>: keeps native semantics + no-JS fallback,
  // but hijacks the toggle to height/opacity/blur-animate the answer. Blur
  // masks the height reflow so the reveal reads as one smooth motion.
  const EASE_OUT = 'cubic-bezier(0.23, 1, 0.32, 1)';
  const EASE_IN = 'cubic-bezier(0.4, 0, 0.6, 1)';
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  document.querySelectorAll<HTMLDetailsElement>('details.faq').forEach((d) => {
    const summary = d.querySelector<HTMLElement>('summary')!;
    const content = d.querySelector<HTMLElement>('.faq-content')!;
    let anim: Animation | null = null;

    summary.addEventListener('click', (e) => {
      if (reduce) return; // let the browser toggle natively
      e.preventDefault();
      anim?.cancel();

      if (!d.open) {
        // Opening: reveal, measure, then grow from zero.
        d.open = true;
        const h = content.offsetHeight;
        anim = content.animate(
          [
            { height: '0px', opacity: 0, filter: 'blur(6px)' },
            { height: `${h}px`, opacity: 1, filter: 'blur(0px)' },
          ],
          { duration: 320, easing: EASE_OUT }
        );
        anim.onfinish = () => {
          content.style.height = '';
          anim = null;
        };
      } else {
        // Closing: collapse to zero, then drop the [open] state.
        const h = content.offsetHeight;
        anim = content.animate(
          [
            { height: `${h}px`, opacity: 1, filter: 'blur(0px)' },
            { height: '0px', opacity: 0, filter: 'blur(6px)' },
          ],
          { duration: 260, easing: EASE_IN }
        );
        anim.onfinish = () => {
          d.open = false;
          anim = null;
        };
      }
    });
  });
</script>
