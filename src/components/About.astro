---
import { ABOUT, IMAGES } from '../consts';

// Words for the band that runs behind the lambo artwork.
const bandItems = ['Window Tint', 'PPF', 'Ceramic Coating', 'Tesla', 'Commercial Film'];
const bandSeq = [...bandItems, ...bandItems, ...bandItems, ...bandItems];
---

<section id="about" class="hex-bg relative overflow-hidden bg-paper">
  <div class="mx-auto max-w-6xl px-5 py-20 md:py-28">
    <!-- Two-column intro: title + CTA left, copy right -->
    <div class="grid gap-10 md:grid-cols-2 md:items-start">
      <div class="reveal">
        <p class="kicker text-accentDk">About us</p>
        <h2 class="headline mt-3 text-[clamp(1.4rem,2.8vw,2.2rem)] text-ink">
          Crafting excellence in surface protection & style
        </h2>
        <a
          href="/#contact"
          class="pressable sticker mt-8 inline-block bg-accent px-8 py-3.5 text-xs font-bold uppercase tracking-[0.12em] text-ink transition-[background-color,transform] duration-200 hover:-translate-y-0.5 hover:bg-accentDk"
        >
          Get a Quote →
        </a>
      </div>
      <div class="reveal space-y-4 text-[15px] leading-relaxed text-char md:pt-8">
        <p>{ABOUT.lead}</p>
        <p>{ABOUT.body1}</p>
        <p>{ABOUT.body2}</p>
      </div>
    </div>

    <!-- Centered artwork with a light-blue band running behind it -->
    <div class="reveal relative mx-auto mt-12 max-w-5xl">
      <!-- Solid white cover: hides the hex pattern from the band downward -->
      <div
        class="pointer-events-none absolute left-1/2 top-1/2 h-screen w-screen -translate-x-1/2 bg-paper"
        aria-hidden="true"
      ></div>

      <!-- Light-blue marquee band, vertically centered behind the image -->
      <div
        class="marquee absolute left-1/2 top-1/2 w-screen -translate-x-1/2 -translate-y-1/2 -rotate-2 bg-[#5FC2FF] py-3"
        aria-hidden="true"
      >
        <div class="marquee-track">
          {
            bandSeq.map((label, i) => (
              <span class="mx-5 flex items-center gap-10 whitespace-nowrap">
                <span
                  class:list={[
                    'headline text-xl tracking-[0.08em]',
                    i % 2 === 0 ? 'text-paper' : 'text-ink/70',
                  ]}
                >
                  {label}
                </span>
                <span class="text-paper">✦</span>
              </span>
            ))
          }
        </div>
      </div>

      <img
        src={IMAGES.install.src}
        alt={IMAGES.install.alt}
        width={IMAGES.install.width}
        height={IMAGES.install.height}
        loading="lazy"
        class="relative mx-auto w-full object-contain"
      />
    </div>
  </div>
</section>
