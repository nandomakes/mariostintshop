---
import { SITE, NAV_LINKS } from '../consts';
---

<header class="sticky top-0 z-50 border-b border-tinta/10 bg-crema/90 backdrop-blur">
  <nav class="mx-auto flex max-w-6xl items-center justify-between px-5 py-3" aria-label="Principal">
    <a href="#inicio" class="leading-none">
      <span class="-mb-1 block font-script text-3xl text-terraInk">{SITE.firstName}</span>
      <span class="text-[10px] uppercase tracking-[0.35em] text-cafe">Nutrióloga · SLP</span>
    </a>

    <ul class="hidden items-center gap-7 text-sm md:flex">
      {
        NAV_LINKS.map((link) => (
          <li>
            <a
              href={link.href}
              class="nav-link py-3 transition-colors duration-200 hover:text-olivaDk"
            >
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>

    <div class="flex items-center gap-2">
      <a
        href="#agenda"
        class="pressable rounded-sm bg-terra px-5 py-3 text-xs uppercase tracking-[0.2em] text-tinta transition-colors duration-200 hover:bg-blush"
      >
        Agendar
      </a>
      <button
        id="menu-toggle"
        type="button"
        class="pressable -mr-1 flex h-11 w-11 items-center justify-center rounded-sm text-tinta md:hidden"
        aria-expanded="false"
        aria-controls="menu-movil"
        aria-label="Abrir menú"
      >
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path class="menu-open" d="M4 7h16M4 12h16M4 17h16"></path>
          <path class="menu-close hidden" d="M6 6l12 12M18 6L6 18"></path>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Menú móvil: animación de altura con la técnica grid-rows 0fr→1fr,
       para un despliegue suave sin saltos (display:none no anima). -->
  <div
    id="menu-movil"
    class="grid grid-rows-[0fr] overflow-hidden border-t border-transparent bg-crema opacity-0 transition-[grid-template-rows,opacity,border-color] duration-300 ease-out md:hidden"
  >
    <div id="menu-inner" class="min-h-0 overflow-hidden">
      <ul class="px-5 py-2">
        {
          NAV_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class="block border-b border-tinta/5 py-3.5 text-sm uppercase tracking-[0.15em] text-tinta transition-colors duration-200 hover:text-olivaDk"
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('menu-movil');
  const inner = document.getElementById('menu-inner');
  if (toggle && menu && inner) {
    const setOpen = (open: boolean) => {
      menu.classList.toggle('grid-rows-[1fr]', open);
      menu.classList.toggle('grid-rows-[0fr]', !open);
      menu.classList.toggle('opacity-100', open);
      menu.classList.toggle('opacity-0', !open);
      menu.classList.toggle('border-tinta/10', open);
      inner.toggleAttribute('inert', !open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Cerrar menú' : 'Abrir menú');
      toggle.querySelector('.menu-open')?.classList.toggle('hidden', open);
      toggle.querySelector('.menu-close')?.classList.toggle('hidden', !open);
    };
    setOpen(false);
    toggle.addEventListener('click', () =>
      setOpen(toggle.getAttribute('aria-expanded') !== 'true')
    );
    // Cierra al navegar a una sección
    menu.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => setOpen(false))
    );
  }
</script>
