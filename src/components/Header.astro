---
import { NAV_LINKS, CONTACT, SOCIALS } from '../consts';
import Logo from './Logo.astro';
---

<!-- Top bar: contact info left, hours + socials right -->
<div class="hidden border-b border-line bg-ink md:block">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-2 text-[11px] font-medium tracking-[0.06em] text-smoke">
    <div class="flex items-center gap-6">
      <a href={`mailto:${CONTACT.email}`} class="flex items-center gap-1.5 transition-colors hover:text-paper">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#00A8FF" stroke-width="2" aria-hidden="true"><rect x="3" y="5" width="18" height="14" rx="2" /><path d="m3 7 9 6 9-6" /></svg>
        {CONTACT.email}
      </a>
      <span class="hidden items-center gap-1.5 lg:flex">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#00A8FF" stroke-width="2" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 1 1 16 0Z" /><circle cx="12" cy="10" r="3" /></svg>
        {CONTACT.address}, {CONTACT.city}
      </span>
    </div>
    <div class="flex items-center gap-6">
      <span class="flex items-center gap-1.5">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="#00A8FF" stroke-width="2" aria-hidden="true"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 3" /></svg>
        {CONTACT.scheduleShort}
      </span>
      <div class="flex items-center gap-4">
        {
          SOCIALS.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="uppercase tracking-[0.14em] transition-colors hover:text-accent"
            >
              {s.name}
            </a>
          ))
        }
      </div>
    </div>
  </div>
</div>

<!-- Main nav: links left · logo center · CTA right -->
<header class="sticky top-0 z-50 border-b border-line bg-ink/95 backdrop-blur">
  <nav
    class="mx-auto grid max-w-6xl grid-cols-[1fr_auto_1fr] items-center px-5 py-3.5"
    aria-label="Primary"
  >
    <ul class="hidden items-center gap-7 justify-self-start text-[11px] font-bold uppercase tracking-[0.16em] text-paper lg:flex">
      {
        NAV_LINKS.map((link) => (
          <li>
            <a href={link.href} class="nav-link py-3 transition-colors duration-200 hover:text-accent">
              {link.label}
            </a>
          </li>
        ))
      }
    </ul>
    <button
      id="menu-toggle"
      type="button"
      class="pressable -ml-2 flex h-11 w-11 items-center justify-center justify-self-start text-paper lg:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="Open menu"
    >
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
        <path class="menu-open" d="M4 7h16M4 12h16M4 17h16"></path>
        <path class="menu-close hidden" d="M6 6l12 12M18 6L6 18"></path>
      </svg>
    </button>

    <a href="/" class="justify-self-center" aria-label="Mario's Tint Shop — home">
      <Logo />
    </a>

    <div class="flex items-center gap-5 justify-self-end">
      <a
        href={`tel:${CONTACT.phoneTel}`}
        class="hidden text-sm font-bold text-paper transition-colors hover:text-accent md:inline"
      >
        {CONTACT.phoneDisplay}
      </a>
      <a
        href="/#contact"
        class="pressable sticker hidden bg-accent px-6 py-2.5 text-[11px] font-bold uppercase tracking-[0.12em] text-ink transition-[background-color,transform] duration-200 hover:-translate-y-0.5 hover:bg-accentDk sm:inline-block"
      >
        Contact Us
      </a>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="grid grid-rows-[0fr] overflow-hidden border-t border-transparent bg-ink opacity-0 transition-[grid-template-rows,opacity,border-color] duration-300 ease-out lg:hidden"
  >
    <div id="menu-inner" class="min-h-0 overflow-hidden">
      <ul class="px-5 py-2">
        {
          NAV_LINKS.map((link) => (
            <li>
              <a
                href={link.href}
                class="block border-b border-line py-3.5 text-sm font-bold uppercase tracking-[0.16em] text-smoke transition-colors duration-200 hover:text-accent"
              >
                {link.label}
              </a>
            </li>
          ))
        }
        <li class="py-4">
          <a
            href="/#contact"
            class="sticker block bg-accent px-6 py-3 text-center text-xs font-bold uppercase tracking-[0.14em] text-ink"
          >
            Contact Us
          </a>
        </li>
      </ul>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  const inner = document.getElementById('menu-inner');
  if (toggle && menu && inner) {
    const setOpen = (open: boolean) => {
      menu.classList.toggle('grid-rows-[1fr]', open);
      menu.classList.toggle('grid-rows-[0fr]', !open);
      menu.classList.toggle('opacity-100', open);
      menu.classList.toggle('opacity-0', !open);
      menu.classList.toggle('border-line', open);
      inner.toggleAttribute('inert', !open);
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      toggle.querySelector('.menu-open')?.classList.toggle('hidden', open);
      toggle.querySelector('.menu-close')?.classList.toggle('hidden', !open);
    };
    setOpen(false);
    toggle.addEventListener('click', () => setOpen(toggle.getAttribute('aria-expanded') !== 'true'));
    menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', () => setOpen(false)));
  }
</script>
