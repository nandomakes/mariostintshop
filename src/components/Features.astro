---
import { BENEFITS, STATS, CONTACT } from '../consts';
---

<section id="why-us" class="bg-paper">
  <div class="mx-auto max-w-6xl px-5 py-20 md:py-24">
    <!-- Benefits -->
    <div class="text-center">
      <p class="reveal kicker text-accentDk">Done with confidence</p>
      <h2 class="reveal headline mx-auto mt-3 max-w-3xl text-[clamp(1.4rem,2.8vw,2.2rem)] text-ink">
        Protecting vehicles, homes & businesses
      </h2>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        BENEFITS.map((b) => (
          <div class="lift border border-sand bg-paper px-6 py-9 text-center shadow-[0_2px_10px_rgba(0,0,0,0.05)]">
            <span class="mx-auto flex h-14 w-14 items-center justify-center bg-accent text-ink" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2 4 5v6c0 5 3.4 9.4 8 11 4.6-1.6 8-6 8-11V5l-8-3Z" />
                <path d="m9 12 2 2 4-4" />
              </svg>
            </span>
            <h3 class="headline mt-5 text-base tracking-[0.06em] text-ink">{b.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-char">{b.body}</p>
          </div>
        ))
      }
    </div>

    <div class="reveal mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="/#contact"
        class="pressable sticker bg-accent px-8 py-3.5 text-center text-xs font-bold uppercase tracking-[0.12em] text-ink transition-[background-color,transform] duration-200 hover:-translate-y-0.5 hover:bg-accentDk"
      >
        Get a Quote →
      </a>
      <a
        href={`tel:${CONTACT.phoneTel}`}
        class="pressable inline-flex items-center justify-center gap-2 px-2 py-3.5 text-sm font-bold text-ink transition-colors hover:text-accentDk"
      >
        <svg width="15" height="15" viewBox="0 0 24 24" fill="#0086D6" aria-hidden="true"><path d="M6.62 10.79a15.53 15.53 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.24.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2Z" /></svg>
        {CONTACT.phoneDisplay}
      </a>
    </div>
  </div>
</section>

<!-- Stats card straddling the white/black seam (top half white, bottom half black) -->
<section class="bg-[linear-gradient(180deg,#FFFFFF_50%,#111111_50%)]">
  <div class="mx-auto max-w-6xl px-5">
    <dl class="grid grid-cols-4 gap-px border border-sand bg-sand shadow-[0_30px_60px_-30px_rgba(0,0,0,0.5)]">
      {
        STATS.map((s) => (
          <div class="wave-bg px-2 py-7 text-center sm:px-5 sm:py-9">
            <dt class="headline text-2xl text-ink sm:text-4xl md:text-5xl">
              {s.num !== undefined ? (
                <>
                  <span data-count={s.num}>0</span>
                  <span class="text-accentDk">{s.suffix}</span>
                </>
              ) : (
                s.text
              )}
            </dt>
            <dd class="mt-2 text-[9px] font-semibold uppercase tracking-[0.12em] text-ash sm:text-[11px] sm:tracking-[0.18em]">{s.label}</dd>
          </div>
        ))
      }
    </dl>
  </div>
</section>
