---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import QuoteCTA from '../components/QuoteCTA.astro';
import Footer from '../components/Footer.astro';
import CallFab from '../components/CallFab.astro';
import { SITE, IMAGES, WHATSAPP_NUMBER } from '../consts';
import { PHOTO_VEHICLES, sedanZonePath } from '../lib/vehicles-photo';

// 3D-only visualizer: one optimized GLB per category (public/models3d/*.glb).
const VEHICLE_IDS = ['sedan', 'suv', 'sport', 'truck'];
const VEHICLES = PHOTO_VEHICLES.filter((v) => VEHICLE_IDS.includes(v.id));

const title = `Window Tint Visualizer | ${SITE.brand}`;
const description =
  "See 3M window tint on a 3D car. Pick a vehicle type, choose the coverage and shade, and rotate the model to preview the look — then send your build to Mario's Tint Shop in Murfreesboro, TN for a free quote.";

// ── Control data ─────────────────────────────────────────────────────
const TINT_ZONES = [
  { id: 'rear-side', label: 'Rear side windows' },
  { id: 'front-side', label: 'Front side windows' },
  { id: 'visor', label: 'Visor strip' },
  { id: 'rear', label: 'Rear window' },
];

// Coverage tiles use the sedan side-view photo (the same imagery as the
// vehicle picker) with the covered glass vectorized on top in accent blue.
const zoneTiles = TINT_ZONES.map((z) => ({ ...z, path: sedanZonePath(z.id) }));
const SHADES = [
  { id: 'dark', label: 'Dark', vlt: 'VLT 5–35', op: 0.85 },
  { id: 'medium', label: 'Medium', vlt: 'VLT 35–65', op: 0.58 },
  { id: 'light', label: 'Light', vlt: 'VLT 65–95', op: 0.32 },
  { id: 'clear', label: 'Clear', vlt: 'VLT 95–100', op: 0.14 },
];
const PRIORITIES = [
  { id: 'price', label: 'Price' },
  { id: 'heat', label: 'Heat rejection' },
  { id: 'signal', label: 'Signal clarity' },
  { id: 'appearance', label: 'Appearance' },
];
---

<Layout title={title} description={description}>
  <Header />
  <main id="content">
    <!-- Hero image band -->
    <section class="relative overflow-hidden border-b border-line bg-ink">
      <div class="absolute inset-0" aria-hidden="true">
        <img
          src={IMAGES.detail.src}
          alt=""
          width={IMAGES.detail.width}
          height={IMAGES.detail.height}
          class="h-full w-full object-cover opacity-60"
        />
        <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/40 to-ink/70"></div>
      </div>
      <div class="relative mx-auto max-w-6xl px-5 pb-14 pt-24 md:pb-20 md:pt-32">
        <nav class="reveal text-[11px] font-bold uppercase tracking-[0.16em] text-smoke" aria-label="Breadcrumb">
          <a href="/" class="transition-colors hover:text-paper">Home</a>
          <span class="mx-2 text-line">/</span>
          <span class="text-accent">Tint visualizer</span>
        </nav>
      </div>
    </section>

    <!-- Title + intro -->
    <section class="border-b border-sand bg-paper">
      <div class="mx-auto max-w-4xl px-5 py-12 text-center md:py-14">
        <h1 class="reveal headline text-[clamp(1.4rem,2.8vw,2.1rem)] text-ink">
          Window tint visualizer
        </h1>
        <p class="reveal mx-auto mt-5 max-w-[64ch] text-[15px] leading-relaxed text-char">
          See 3M window tint on your car. Select a car category, determine the coverage
          area, pick a shade, and rotate the 3D model to preview the look — before you buy.
        </p>
      </div>
    </section>

    <!-- Vehicle type strip -->
    <section class="border-b border-sand bg-paper">
      <div class="mx-auto max-w-4xl px-5 py-6">
        <div class="grid grid-cols-2 gap-2 sm:grid-cols-4" role="radiogroup" aria-label="Vehicle type">
          {
            VEHICLES.map((v, i) => (
              <button
                type="button"
                role="radio"
                aria-checked={i === 0 ? 'true' : 'false'}
                data-vehicle={v.id}
                data-vehicle-label={v.label}
                class:list={[
                  'veh-chip pressable group flex flex-col items-center gap-1.5 border px-2 pb-2.5 pt-3 transition-colors duration-200',
                  i === 0 ? 'border-accent bg-mint' : 'border-sand hover:border-ash/60',
                ]}
              >
                <img
                  src={v.photo}
                  alt=""
                  width="120"
                  height="47"
                  loading="lazy"
                  class="veh-thumb h-9 w-full object-contain transition-[filter,opacity] duration-200"
                />
                <span class="text-[10px] font-bold uppercase tracking-[0.14em] text-ink transition-colors group-aria-checked:text-accentDk">
                  {v.label}
                </span>
              </button>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Visualizer: controls left · 3D preview right -->
    <section id="visualizer" class="bg-paper">
      <div class="mx-auto grid max-w-6xl gap-8 px-5 py-10 md:py-14 lg:grid-cols-[5fr_7fr] lg:items-start">
        <!-- Controls column -->
        <div class="min-w-0 border border-sand bg-whisper lg:order-1">
          <!-- Header + reset -->
          <div class="flex items-center border-b border-sand pr-3">
            <span class="relative px-4 py-3.5 text-[11px] font-bold uppercase tracking-[0.12em] text-accentDk">
              Window Tint
              <span class="absolute inset-x-0 bottom-0 h-0.5 bg-accent"></span>
            </span>
            <button
              type="button" id="reset-btn"
              class="pressable ml-auto flex items-center gap-1.5 px-2 py-2 text-[10px] font-bold uppercase tracking-[0.12em] text-ash transition-colors hover:text-accentDk"
            >
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><path d="M3 3v5h5"/></svg>
              <span class="hidden sm:inline">Start over</span>
            </button>
          </div>

          <!-- Accordion: coverage -->
          <div class="acc border-b border-sand px-6" data-open="true">
            <button type="button" class="acc-toggle flex w-full items-center justify-between py-4 text-left" aria-expanded="true">
              <span>
                <span class="block text-[11px] font-bold uppercase tracking-[0.16em] text-ink">Select the coverage</span>
                <span class="mt-0.5 block text-xs text-ash">Select a coverage zone to get started.</span>
              </span>
              <svg class="acc-icon shrink-0 text-accentDk transition-transform duration-300 ease-[cubic-bezier(0.23,1,0.32,1)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true">
                <path d="M5 12h14" /><path class="acc-vert" d="M12 5v14" />
              </svg>
            </button>
            <div class="acc-body grid grid-rows-[1fr] transition-[grid-template-rows] duration-300 ease-[cubic-bezier(0.23,1,0.32,1)]">
              <div class="min-h-0 overflow-hidden">
                <div class="grid grid-cols-2 gap-2 pb-5 sm:grid-cols-4">
                  {
                    zoneTiles.map((z) => (
                      <button
                        type="button"
                        data-tint-zone={z.id}
                        aria-pressed={z.id === 'front-side' || z.id === 'rear-side' ? 'true' : 'false'}
                        class="zone-tile pressable group flex flex-col items-center gap-1 border border-sand bg-paper px-1.5 pb-2 pt-2.5 transition-colors duration-200 hover:border-ash/60 aria-pressed:border-accent aria-pressed:bg-mint"
                      >
                        <svg viewBox="30 70 800 265" class="h-10 w-full" aria-hidden="true">
                          <image href="/images/vehicles/sedan.png" x="0" y="0" width="860" height="340" />
                          <path d={z.path} fill="#00A8E8" fill-opacity="0.9" stroke="#0077B6" stroke-width="1.5" />
                        </svg>
                        <span class="text-center text-[10px] font-bold leading-tight text-ink group-aria-pressed:text-accentDk">{z.label}</span>
                      </button>
                    ))
                  }
                </div>
              </div>
            </div>
          </div>

          <!-- Accordion: tint shade -->
          <div class="acc border-b border-sand px-6" data-open="true">
            <button type="button" class="acc-toggle flex w-full items-center justify-between py-4 text-left" aria-expanded="true">
              <span>
                <span class="block text-[11px] font-bold uppercase tracking-[0.16em] text-ink">Select the tint</span>
                <span class="mt-0.5 block text-xs text-ash">The shade applies live to the 3D model's glass.</span>
              </span>
              <svg class="acc-icon shrink-0 text-accentDk transition-transform duration-300 ease-[cubic-bezier(0.23,1,0.32,1)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true">
                <path d="M5 12h14" /><path class="acc-vert" d="M12 5v14" />
              </svg>
            </button>
            <div class="acc-body grid grid-rows-[1fr] transition-[grid-template-rows] duration-300 ease-[cubic-bezier(0.23,1,0.32,1)]">
              <div class="min-h-0 overflow-hidden">
                <div class="grid grid-cols-4 gap-2" role="radiogroup" aria-label="Tint shade">
                  {
                    SHADES.map((s) => (
                      <button
                        type="button" role="radio"
                        aria-checked={s.id === 'dark' ? 'true' : 'false'}
                        data-shade={s.id} data-shade-label={s.label} data-op={s.op}
                        class="shade-chip pressable border border-sand bg-paper p-2 text-center transition-colors duration-200 hover:border-ash/60 aria-checked:border-accent"
                      >
                        <span
                          class="block h-8 w-full border border-sand"
                          style={`background: linear-gradient(rgba(11,21,36,${s.op}), rgba(11,21,36,${s.op})), linear-gradient(135deg, #E8F1F8 0%, #BFD3E2 60%, #DCE9F4 100%)`}
                          aria-hidden="true"
                        />
                        <span class="mt-1.5 block text-xs font-bold text-ink">{s.label}</span>
                        <span class="block text-[10px] text-ash">{s.vlt}</span>
                      </button>
                    ))
                  }
                </div>
                <p class="pb-5 pt-2 text-[11px] leading-relaxed text-ash">
                  Tennessee requires 35%+ VLT on front side windows.
                </p>
              </div>
            </div>
          </div>

          <!-- Accordion: priorities -->
          <div class="acc px-6" data-open="true">
            <button type="button" class="acc-toggle flex w-full items-center justify-between py-4 text-left" aria-expanded="true">
              <span>
                <span class="block text-[11px] font-bold uppercase tracking-[0.16em] text-ink">What matters most?</span>
                <span class="mt-0.5 block text-xs text-ash">Prioritize these benefits to help us find the right tint for you.</span>
              </span>
              <svg class="acc-icon shrink-0 text-accentDk transition-transform duration-300 ease-[cubic-bezier(0.23,1,0.32,1)]" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" aria-hidden="true">
                <path d="M5 12h14" /><path class="acc-vert" d="M12 5v14" />
              </svg>
            </button>
            <div class="acc-body grid grid-rows-[1fr] transition-[grid-template-rows] duration-300 ease-[cubic-bezier(0.23,1,0.32,1)]">
              <div class="min-h-0 overflow-hidden">
                <div class="flex flex-wrap gap-2 pb-5">
                  {
                    PRIORITIES.map((p) => (
                      <button
                        type="button"
                        data-priority={p.id}
                        aria-pressed="false"
                        class="prio-chip pressable border border-sand bg-paper px-3.5 py-2 text-xs font-bold text-ink transition-colors duration-200 hover:border-ash/60 aria-pressed:border-accent aria-pressed:bg-accent aria-pressed:text-ink"
                      >
                        {p.label}
                      </button>
                    ))
                  }
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Preview column: 3D model on a white stage -->
        <div class="min-w-0 lg:order-2">
          <div class="border border-sand bg-whisper p-4 sm:p-6">
            <!-- Toolbar: angle toggle left · PDF download top-right -->
            <div class="mb-3 flex items-center justify-between gap-2">
              <div class="flex items-center gap-1" role="tablist" aria-label="Vehicle angle">
                <button
                  type="button" data-angle="front" aria-pressed="true"
                  class="angle-btn pressable border border-sand bg-paper px-3 py-1.5 text-[10px] font-bold uppercase tracking-[0.12em] text-ink transition-colors duration-200 aria-pressed:border-accent aria-pressed:bg-accent"
                >
                  Front view
                </button>
                <button
                  type="button" data-angle="rear" aria-pressed="false"
                  class="angle-btn pressable border border-sand bg-paper px-3 py-1.5 text-[10px] font-bold uppercase tracking-[0.12em] text-ink transition-colors duration-200 aria-pressed:border-accent aria-pressed:bg-accent"
                >
                  Rear view
                </button>
              </div>
              <button
                type="button"
                id="pdf-btn"
                class="pressable flex items-center gap-1.5 border border-sand bg-paper px-3 py-1.5 text-[10px] font-bold uppercase tracking-[0.12em] text-ink transition-colors duration-200 hover:border-accent hover:text-accentDk"
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><path d="M7 10l5 5 5-5"/><path d="M12 15V3"/></svg>
                <span class="hidden sm:inline">Download PDF</span>
                <span class="sm:hidden">PDF</span>
              </button>
            </div>

            <div class="relative w-full overflow-hidden border border-sand bg-white" style="aspect-ratio: 860 / 520;">
              <model-viewer
                id="car-3d-viewer"
                class="absolute inset-0 h-full w-full"
                style="background-color: #ffffff;"
                src="/models3d/sedan.glb"
                loading="eager"
                bounds="tight"
                shadow-intensity="0.9"
                shadow-softness="0.8"
                exposure="1.1"
                environment-image="neutral"
                camera-orbit="-35deg 78deg 75%"
                field-of-view="20deg"
                disable-zoom
                disable-tap
                interaction-prompt="none"
                aria-label="3D vehicle with the selected tint applied to the glass"
              ></model-viewer>
            </div>
            <p class="mt-2 text-[10px] leading-relaxed text-ash">
              Switch between front and rear view · pick a tint shade to see it on the glass
            </p>

            <!-- Live summary -->
            <div class="mt-3 flex flex-wrap items-center justify-between gap-3 border-t border-sand pt-4">
              <p id="build-summary" class="min-w-0 flex-1 text-xs font-semibold uppercase tracking-[0.08em] text-char"></p>
              <span id="legal-badge" class="shrink-0 bg-accent/15 px-3 py-1.5 text-[10px] font-bold uppercase tracking-[0.12em] text-accentDk"></span>
            </div>
          </div>

          <!-- CTAs under the preview -->
          <a
            id="visualizer-cta"
            href={`https://wa.me/${WHATSAPP_NUMBER}`}
            target="_blank"
            rel="noopener noreferrer"
            class="pressable sticker mx-auto mt-6 block max-w-md bg-accent px-8 py-4 text-center text-xs font-bold uppercase tracking-[0.12em] text-ink transition-[background-color,transform] duration-200 hover:-translate-y-0.5 hover:bg-accentDk"
          >
            Contact Your Installer →
          </a>
          <p class="mt-2.5 text-center text-[11px] text-ash">
            Opens WhatsApp with your build pre-filled — we reply with a free quote.
          </p>

          <p class="mx-auto mt-6 max-w-xl text-center text-[11px] leading-relaxed text-ash">
            Visual representations are shown for illustrative purposes only; vehicles are
            generic 3D models and actual appearances treated with window film may vary.
          </p>
        </div>
      </div>
    </section>

    <QuoteCTA />
  </main>
  <Footer />
  <CallFab />

  <style>
    /* Photo thumbnails in the vehicle picker: dim until selected. */
    .veh-chip .veh-thumb {
      filter: grayscale(0.5) brightness(0.97);
      opacity: 0.62;
    }
    .veh-chip[aria-checked='true'] .veh-thumb {
      filter: none;
      opacity: 1;
    }

    /* Accordions: +/− icon morph and body collapse. */
    .acc[data-open='false'] .acc-body {
      grid-template-rows: 0fr;
    }
    .acc .acc-icon .acc-vert {
      transition: transform 300ms var(--ease-out), opacity 300ms var(--ease-out);
      transform-origin: center;
    }
    .acc[data-open='true'] .acc-icon .acc-vert {
      transform: scaleY(0);
      opacity: 0;
    }

    @media (prefers-reduced-motion: reduce) {
      .acc-body {
        transition: none !important;
      }
    }
  </style>

  <script>
    // model-viewer registers <model-viewer> as a custom element on import.
    // Dynamic chunk: it loads after the page shell renders.
    import('@google/model-viewer');

    const $$ = <T extends HTMLElement = HTMLElement>(sel: string) =>
      Array.from(document.querySelectorAll<T>(sel));

    // ══ Visualizer state ═════════════════════════════════════════════
    const state = {
      vehicle: 'sedan',
      vehicleLabel: 'Sedan',
      tintZones: new Set(['front-side', 'rear-side']),
      shade: 'dark',
      shadeLabel: 'Dark',
      shadeOp: 0.85,
      priorities: new Set<string>(),
    };

    const ZONE_LABELS: Record<string, string> = {
      'rear-side': 'Rear side windows',
      'front-side': 'Front side windows',
      rear: 'Rear window',
      visor: 'Visor strip',
      price: 'Price',
      heat: 'Heat rejection',
      signal: 'Signal clarity',
      appearance: 'Appearance',
    };
    const SHADE_META: Record<string, { vlt: string; frontLegal: boolean }> = {
      dark: { vlt: 'VLT 5–35', frontLegal: false },
      medium: { vlt: 'VLT 35–65', frontLegal: true },
      light: { vlt: 'VLT 65–95', frontLegal: true },
      clear: { vlt: 'VLT 95–100', frontLegal: true },
    };

    const summary = document.getElementById('build-summary')!;
    const badge = document.getElementById('legal-badge')!;
    const cta = document.getElementById('visualizer-cta') as HTMLAnchorElement;

    // ══ 3D viewer ═════════════════════════════════════════════════════
    type GlbMaterial = {
      name: string;
      pbrMetallicRoughness: { setBaseColorFactor(rgba: number[]): void; baseColorFactor: number[] };
    };
    const viewer = document.getElementById('car-3d-viewer') as HTMLElement & {
      src: string;
      cameraOrbit: string;
      cameraTarget: string;
      jumpCameraToGoal(): void;
      toDataURL(type?: string): string;
      model?: { materials: GlbMaterial[] };
    };

    let currentSrc = '';

    // Glass looks per shade — must match GLASS_LOOK in scripts/build-models.mjs.
    const GLASS_LOOK: Record<string, number[]> = {
      clear: [0.8, 0.84, 0.88, 0.18],
      light: [0.5, 0.54, 0.58, 0.42],
      medium: [0.17, 0.19, 0.21, 0.66],
      dark: [0.02, 0.024, 0.03, 0.88],
    };
    // Each coverage zone owns a glass material, split at build time.
    // glass_windshield and glass_lamps are never tinted.
    const ZONE_MATERIAL: Record<string, string> = {
      'front-side': 'glass_front',
      'rear-side': 'glass_rearside',
      rear: 'glass_rearwin',
      visor: 'glass_visor',
    };

    // Apply the selected shade to the selected zones' glass materials and
    // reset unselected zones to clear. three.js re-syncs materials
    // asynchronously while textures wire up and can overwrite live edits,
    // so a permanent watchdog re-asserts the state every 700ms — any revert
    // is corrected within a frame or two of it happening.
    function applyTint3D() {
      const materials = viewer.model?.materials;
      if (!materials?.length) return;
      const shadeLook = GLASS_LOOK[state.shade] ?? GLASS_LOOK.dark;
      const wanted: Record<string, number[]> = {
        glass_windshield: GLASS_LOOK.clear,
        glass_lamps: GLASS_LOOK.clear,
      };
      for (const [zone, matName] of Object.entries(ZONE_MATERIAL)) {
        wanted[matName] = state.tintZones.has(zone) ? shadeLook : GLASS_LOOK.clear;
      }
      for (const mat of materials) {
        const target = wanted[mat.name];
        if (target) mat.pbrMetallicRoughness.setBaseColorFactor(target);
      }
    }
    setInterval(applyTint3D, 700);

    // Fixed ¾ camera angles. The Raptor rip faces the opposite way from the
    // other three models, so its front theta is offset 180°.
    const FRONT_THETA: Record<string, number> = { sedan: -35, suv: -35, sport: -35, truck: 145 };
    let angle: 'front' | 'rear' = 'front';
    // Auto-framing centers the 3D bounding box, but a ¾ view carries more
    // visual mass toward the near end — nudge the camera target 7% of the
    // car's length toward the nose (sign flips with model facing + view).
    let modelCenter: { x: number; y: number; z: number } | null = null;
    let modelLength = 0;
    function applyAngle() {
      const front = FRONT_THETA[state.vehicle] ?? -35;
      const theta = angle === 'front' ? front : front + 180;
      viewer.cameraOrbit = `${theta}deg 78deg 75%`;
      if (modelCenter) {
        const facing = front === -35 ? 1 : -1;
        const dir = facing * (angle === 'front' ? 1 : -1);
        viewer.cameraTarget = `${modelCenter.x}m ${modelCenter.y}m ${modelCenter.z + dir * modelLength * 0.07}m`;
      }
      viewer.jumpCameraToGoal?.();
    }
    $$('.angle-btn').forEach((b) =>
      b.addEventListener('click', () => {
        angle = b.dataset.angle as 'front' | 'rear';
        $$('.angle-btn').forEach((c) => c.setAttribute('aria-pressed', String(c === b)));
        applyAngle();
      })
    );

    let prefetched = false;
    viewer.addEventListener('load', () => {
      applyTint3D();
      // Capture the auto-framed center of THIS model, then re-frame with
      // the nose-shift applied.
      try {
        const t = (viewer as any).getCameraTarget();
        const d = (viewer as any).getDimensions();
        modelCenter = { x: t.x, y: t.y, z: t.z };
        modelLength = Math.max(d.x, d.z);
      } catch {
        modelCenter = null;
      }
      applyAngle();
      if (!prefetched) {
        prefetched = true;
        prefetchOthers();
      }
    });

    function loadModel(vehicleId: string) {
      const src = `/models3d/${vehicleId}.glb`;
      if (currentSrc === src) return;
      currentSrc = src;
      modelCenter = null;
      (viewer as any).cameraTarget = 'auto auto auto'; // re-resolve for the new model
      viewer.src = src;
      applyAngle();
    }

    // Warm the HTTP cache for the other models so switching vehicles is
    // nearly instant (the GLBs are 2-3.7MB each; decode is the only cost left).
    function prefetchOthers() {
      for (const id of ['suv', 'sport', 'truck']) {
        fetch(`/models3d/${id}.glb`, { priority: 'low' } as RequestInit).catch(() => {});
      }
    }

    // ══ Render cycle ═══════════════════════════════════════════════════
    function render() {
      applyTint3D();

      const zones = [...state.tintZones].map((z) => ZONE_LABELS[z]).join(', ') || 'no zones yet';
      summary.textContent = `${state.vehicleLabel} · ${state.shadeLabel} (${SHADE_META[state.shade].vlt}) · ${zones}`;

      const frontTinted = state.tintZones.has('front-side');
      const legal = !frontTinted || SHADE_META[state.shade].frontLegal;
      badge.textContent = legal ? 'TN legal · selected zones' : 'TN: 35%+ required on front sides';
      badge.className = legal
        ? 'shrink-0 bg-accent/15 px-3 py-1.5 text-[10px] font-bold uppercase tracking-[0.12em] text-accentDk'
        : 'shrink-0 bg-[#FFF1CC] px-3 py-1.5 text-[10px] font-bold uppercase tracking-[0.12em] text-[#8A5B00]';

      const zonesMsg = [...state.tintZones].map((z) => ZONE_LABELS[z]).join(', ') || 'to be decided';
      const prio = [...state.priorities].map((p) => ZONE_LABELS[p] ?? p).join(', ');
      const msg =
        `Hi! I built this in your tint visualizer — Window tint on a ${state.vehicleLabel.toLowerCase()}.` +
        ` Zones: ${zonesMsg}. Shade: ${state.shadeLabel} (${SHADE_META[state.shade].vlt}).` +
        (prio ? ` Priorities: ${prio}.` : '') +
        ` Can I get a quote?`;
      cta.href = `${cta.href.split('?')[0]}?text=${encodeURIComponent(msg)}`;
    }

    // ══ Controls ═══════════════════════════════════════════════════════
    $$('.veh-chip').forEach((chip) =>
      chip.addEventListener('click', () => {
        const id = chip.dataset.vehicle!;
        if (state.vehicle === id) return;
        state.vehicle = id;
        state.vehicleLabel = chip.dataset.vehicleLabel!;
        $$('.veh-chip').forEach((c) => {
          const on = c === chip;
          c.setAttribute('aria-checked', String(on));
          c.classList.toggle('border-accent', on);
          c.classList.toggle('bg-mint', on);
          c.classList.toggle('border-sand', !on);
        });
        loadModel(id);
        render();
      })
    );

    $$('.zone-tile[data-tint-zone]').forEach((tile) =>
      tile.addEventListener('click', () => {
        const z = tile.dataset.tintZone!;
        if (state.tintZones.has(z)) state.tintZones.delete(z);
        else state.tintZones.add(z);
        tile.setAttribute('aria-pressed', String(state.tintZones.has(z)));
        render();
      })
    );

    $$('.shade-chip').forEach((chip) =>
      chip.addEventListener('click', () => {
        state.shade = chip.dataset.shade!;
        state.shadeLabel = chip.dataset.shadeLabel!;
        state.shadeOp = Number(chip.dataset.op);
        $$('.shade-chip').forEach((c) => c.setAttribute('aria-checked', String(c === chip)));
        render();
      })
    );

    $$('.prio-chip').forEach((chip) =>
      chip.addEventListener('click', () => {
        const p = chip.dataset.priority!;
        if (state.priorities.has(p)) state.priorities.delete(p);
        else state.priorities.add(p);
        chip.setAttribute('aria-pressed', String(state.priorities.has(p)));
        render();
      })
    );

    // Accordions
    $$('.acc-toggle').forEach((btn) =>
      btn.addEventListener('click', () => {
        const acc = btn.closest('.acc') as HTMLElement;
        const open = acc.dataset.open === 'true';
        acc.dataset.open = String(!open);
        btn.setAttribute('aria-expanded', String(!open));
      })
    );

    // Start over
    document.getElementById('reset-btn')!.addEventListener('click', () => {
      state.tintZones = new Set(['front-side', 'rear-side']);
      state.shade = 'dark';
      state.shadeLabel = 'Dark';
      state.shadeOp = 0.85;
      state.priorities = new Set();
      $$('.zone-tile[data-tint-zone]').forEach((t) =>
        t.setAttribute('aria-pressed', String(state.tintZones.has(t.dataset.tintZone!)))
      );
      $$('.shade-chip').forEach((c) => c.setAttribute('aria-checked', String(c.dataset.shade === 'dark')));
      $$('.prio-chip').forEach((c) => c.setAttribute('aria-pressed', 'false'));
      angle = 'front';
      $$('.angle-btn').forEach((c) => c.setAttribute('aria-pressed', String(c.dataset.angle === 'front')));
      applyAngle();
      render();
    });

    // ══ Boot ═══════════════════════════════════════════════════════════
    // The initial model comes from the markup's src; its glass is harvested
    // by the permanent 'load' listener above. If the custom element upgraded
    // and loaded before this script attached the listener, harvest once now.
    currentSrc = '/models3d/sedan.glb'; // matches the src baked into the markup
    render();

    // ══ PDF configuration download (SunTek-style summary sheet) ═════════
    document.getElementById('pdf-btn')!.addEventListener('click', async () => {
      const btn = document.getElementById('pdf-btn') as HTMLButtonElement;
      btn.disabled = true;
      btn.style.opacity = '0.5';
      try {
        const { jsPDF } = await import('jspdf');
        const doc = new jsPDF({ unit: 'mm', format: 'a4' });
        const W = 210;
        const zones = [...state.tintZones].map((z) => ZONE_LABELS[z]).join(', ') || 'To be decided';
        const prio = [...state.priorities].map((p) => ZONE_LABELS[p] ?? p).join(', ') || '—';
        const frontTinted = state.tintZones.has('front-side');
        const legal = !frontTinted || SHADE_META[state.shade].frontLegal;

        // Header band
        doc.setFillColor(11, 21, 36);
        doc.rect(0, 0, W, 30, 'F');
        doc.setTextColor(255, 255, 255);
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(16);
        doc.text("MARIO'S TINT SHOP", 14, 13);
        doc.setFontSize(9);
        doc.setFont('helvetica', 'normal');
        doc.text('Window Tint Configuration · Murfreesboro, TN', 14, 20);
        doc.setFontSize(8);
        doc.text(new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }), W - 14, 13, { align: 'right' });

        // Vehicle snapshot from the 3D viewer
        try {
          const shot = viewer.toDataURL('image/png');
          doc.setFillColor(255, 255, 255);
          doc.setDrawColor(224, 219, 209);
          doc.rect(14, 38, W - 28, 92, 'S');
          doc.addImage(shot, 'PNG', 16, 40, W - 32, 88, undefined, 'FAST');
        } catch {
          /* snapshot unavailable — PDF still carries the config table */
        }

        // Configuration table
        let y = 142;
        doc.setTextColor(26, 28, 32);
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(12);
        doc.text('Your build', 14, y);
        y += 8;
        const row = (label: string, value: string) => {
          doc.setFont('helvetica', 'bold');
          doc.setFontSize(9);
          doc.setTextColor(120, 116, 108);
          doc.text(label.toUpperCase(), 14, y);
          doc.setFont('helvetica', 'normal');
          doc.setFontSize(10);
          doc.setTextColor(26, 28, 32);
          const lines = doc.splitTextToSize(value, W - 78);
          doc.text(lines, 64, y);
          y += 7 * lines.length;
          doc.setDrawColor(235, 231, 223);
          doc.line(14, y - 4.5, W - 14, y - 4.5);
        };
        row('Vehicle type', state.vehicleLabel);
        row('Film type', 'Window Tint (3M)');
        row('Coverage zones', zones);
        row('Tint shade', `${state.shadeLabel} (${SHADE_META[state.shade].vlt})`);
        row('Priorities', prio);
        row('TN legality', legal ? 'Legal for the selected zones' : 'Tennessee requires 35%+ VLT on front side windows');

        // Footer
        y = 272;
        doc.setFillColor(245, 242, 236);
        doc.rect(0, y - 8, W, 40, 'F');
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(10);
        doc.setTextColor(26, 28, 32);
        doc.text('Ready for a free quote?', 14, y);
        doc.setFont('helvetica', 'normal');
        doc.setFontSize(9);
        doc.setTextColor(90, 86, 80);
        doc.text('Send this configuration via WhatsApp or bring it to the shop — we reply fast.', 14, y + 6);
        doc.setTextColor(26, 28, 32);
        doc.text("Mario's Tint Shop · Murfreesboro, Tennessee", 14, y + 14);
        doc.setFontSize(7.5);
        doc.setTextColor(140, 136, 128);
        doc.text('Visual representations are illustrative only; vehicles are generic 3D models and actual film appearance may vary.', 14, y + 21);

        doc.save('marios-tint-shop-configuration.pdf');
      } finally {
        btn.disabled = false;
        btn.style.opacity = '';
      }
    });
  </script>
</Layout>
