---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import QuoteCTA from '../components/QuoteCTA.astro';
import Footer from '../components/Footer.astro';
import CallFab from '../components/CallFab.astro';
import { SITE, WHATSAPP_NUMBER } from '../consts';

const title = `Tint & PPF Visualizer | ${SITE.brand}`;
const description =
  "See window tint and paint protection film on your car before you book. Pick your vehicle type, choose coverage zones and tint shade or PPF finish, then send your build to Mario's Tint Shop in Murfreesboro, TN for a free quote.";

// ════════════════════════════════════════════════════════════════════
// PARAMETRIC VEHICLE GENERATOR
// One topology (front fascia → hood → windshield → roof → rear → wheels)
// driven by per-vehicle configs, so every coverage overlay is derived
// from the same anchor points and always lines up with the body.
// viewBox: 0 0 860 340 · ground at y=308
// ════════════════════════════════════════════════════════════════════
import { VEHICLES, initial } from '../lib/vehicles';

// ── Control data ─────────────────────────────────────────────────────
const TINT_ZONES = [
  { id: 'front-side', label: 'Front side windows' },
  { id: 'rear-side', label: 'Rear side windows' },
  { id: 'rear', label: 'Rear window' },
  { id: 'visor', label: 'Visor strip' },
  { id: 'sunroof', label: 'Sunroof' },
];
const SHADES = [
  { id: 'dark', label: 'Dark', vlt: 'VLT 5–35', op: 0.85 },
  { id: 'medium', label: 'Medium', vlt: 'VLT 35–65', op: 0.58 },
  { id: 'light', label: 'Light', vlt: 'VLT 65–95', op: 0.32 },
  { id: 'clear', label: 'Clear', vlt: 'VLT 95–100', op: 0.14 },
];
const PPF_ZONES = [
  { id: 'bumper-front', label: 'Front bumper' },
  { id: 'hood-full', label: 'Full hood' },
  { id: 'hood-partial', label: 'Partial hood' },
  { id: 'fenders-full', label: 'Full fenders' },
  { id: 'fenders-partial', label: 'Partial fenders' },
  { id: 'mirrors', label: 'Side mirrors' },
  { id: 'doors', label: 'Door panels' },
  { id: 'handles', label: 'Door handles' },
  { id: 'door-edges', label: 'Door edges' },
  { id: 'rocker', label: 'Rocker panels' },
  { id: 'roof', label: 'Roof' },
  { id: 'trunk', label: 'Trunk / tailgate' },
  { id: 'bumper-rear', label: 'Rear bumper' },
  { id: 'full', label: 'Full coverage' },
];
const FINISHES = [
  { id: 'gloss', label: 'Gloss', note: 'High-gloss self-healing top coat. Gloss PPF is clear — shown in blue for illustration.' },
  { id: 'matte', label: 'Matte', note: 'Satin finish that turns gloss paint into a smooth matte look.' },
  { id: 'black', label: 'Stealth Black', note: 'Satin-black film that restyles any paint color.' },
];
const PRIORITIES = [
  { id: 'price', label: 'Price' },
  { id: 'heat', label: 'Heat rejection' },
  { id: 'signal', label: 'Signal clarity' },
  { id: 'appearance', label: 'Appearance' },
];
const PAINTS = [
  { id: 'black', label: 'Black', hex: '#1A1C20' },
  { id: 'white', label: 'White', hex: '#E9EAEC' },
  { id: 'silver', label: 'Silver', hex: '#AEB4BC' },
  { id: 'graphite', label: 'Graphite', hex: '#4E545C' },
  { id: 'red', label: 'Red', hex: '#A6182F' },
  { id: 'blue', label: 'Blue', hex: '#1E4FBF' },
];
---

<Layout title={title} description={description}>
  <Header />
  <main id="content">
    <!-- Intro -->
    <section class="border-b border-line bg-ink">
      <div class="mx-auto max-w-6xl px-5 py-12 text-center md:py-16">
        <p class="reveal kicker text-accent">Film visualizer</p>
        <h1 class="reveal headline mt-3 text-[clamp(1.5rem,3.2vw,2.4rem)] text-paper">
          See tint & PPF on your car
        </h1>
        <p class="reveal mx-auto mt-4 max-w-[60ch] text-[15px] leading-relaxed text-smoke">
          Select a vehicle category, choose the coverage area, pick your film — then preview
          the look and send us your build for a free quote.
        </p>
      </div>
    </section>

    <!-- Step 1 · Vehicle type strip -->
    <section class="border-b border-line bg-coal">
      <div class="mx-auto max-w-6xl px-5 py-6">
        <p class="text-center text-[11px] font-bold uppercase tracking-[0.16em] text-smoke">
          1 · Select your vehicle type
        </p>
        <div class="mt-4 grid grid-cols-3 gap-2 sm:grid-cols-6" role="radiogroup" aria-label="Vehicle type">
          {
            VEHICLES.map((v, i) => (
              <button
                type="button"
                role="radio"
                aria-checked={i === 0 ? 'true' : 'false'}
                data-vehicle={v.id}
                class:list={[
                  'veh-chip pressable group flex flex-col items-center gap-1.5 border px-2 pb-2.5 pt-3 transition-colors duration-200',
                  i === 0 ? 'border-accent bg-accent/10' : 'border-line hover:border-smoke/50',
                ]}
              >
                <svg viewBox="0 0 860 340" class="h-9 w-full" aria-hidden="true">
                  <g set:html={v.inner} />
                </svg>
                <span class="text-[10px] font-bold uppercase tracking-[0.14em] text-paper transition-colors group-aria-checked:text-accent">
                  {v.label}
                </span>
              </button>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Visualizer -->
    <section id="visualizer" class="bg-ink" data-mode="tint" data-shade="dark" data-finish="gloss">
      <div class="mx-auto grid max-w-6xl gap-8 px-5 py-10 md:py-14 lg:grid-cols-[7fr_5fr] lg:items-start">
        <!-- Preview (sticky on desktop) -->
        <div class="min-w-0 lg:sticky lg:top-24">
          <div class="border border-line bg-coal">
            <!-- Mode tabs -->
            <div class="flex items-center border-b border-line" role="tablist" aria-label="Film type">
              <button
                type="button" role="tab" aria-selected="true" data-tab="tint"
                class="mode-tab relative px-5 py-3.5 text-[11px] font-bold uppercase tracking-[0.12em] text-accent transition-colors duration-200"
              >
                Window Tint
                <span class="tab-line absolute inset-x-0 bottom-0 h-0.5 origin-left bg-accent transition-transform duration-300 ease-[cubic-bezier(0.23,1,0.32,1)]"></span>
              </button>
              <button
                type="button" role="tab" aria-selected="false" data-tab="ppf"
                class="mode-tab relative px-5 py-3.5 text-[11px] font-bold uppercase tracking-[0.12em] text-smoke transition-colors duration-200 hover:text-paper"
              >
                Paint Protection
                <span class="tab-line absolute inset-x-0 bottom-0 h-0.5 origin-left scale-x-0 bg-accent transition-transform duration-300 ease-[cubic-bezier(0.23,1,0.32,1)]"></span>
              </button>
              <button
                type="button" id="reset-btn"
                class="pressable ml-auto mr-3 flex items-center gap-1.5 px-2 py-2 text-[10px] font-bold uppercase tracking-[0.12em] text-smoke transition-colors hover:text-accent"
              >
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><path d="M3 3v5h5"/></svg>
                Start over
              </button>
            </div>

            <!-- Car stage -->
            <div class="p-4 sm:p-6">
              <svg id="car-svg" viewBox="0 0 860 340" class="h-auto w-full" role="img" aria-label="Vehicle preview with selected film applied">
                <defs>
                  <linearGradient id="body-gloss" x1="0" y1="0" x2="0" y2="1">
                    <stop offset="0" stop-color="#FFFFFF" stop-opacity="0.28" />
                    <stop offset="0.38" stop-color="#FFFFFF" stop-opacity="0.07" />
                    <stop offset="0.62" stop-color="#FFFFFF" stop-opacity="0" />
                    <stop offset="1" stop-color="#000000" stop-opacity="0.2" />
                  </linearGradient>
                </defs>
                <g id="car-root" set:html={initial.inner} />
              </svg>

              <!-- Live summary -->
              <div class="mt-3 flex flex-wrap items-center justify-between gap-3 border-t border-line pt-4">
                <p id="build-summary" class="min-w-0 flex-1 text-xs font-semibold uppercase tracking-[0.08em] text-smoke"></p>
                <span id="legal-badge" class="shrink-0 bg-accent/15 px-3 py-1.5 text-[10px] font-bold uppercase tracking-[0.12em] text-accent"></span>
              </div>
            </div>
          </div>

          <p class="mt-3 text-[11px] leading-relaxed text-smoke/70">
            Visual representations are for illustration only — actual film appearance varies by
            vehicle, glass, and lighting. Gloss PPF is optically clear; zones are shown in blue.
          </p>
        </div>

        <!-- Controls -->
        <div class="min-w-0">
          <!-- Paint color -->
          <div class="border border-line bg-coal p-6">
            <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-smoke">Paint color</p>
            <div class="mt-3 flex flex-wrap gap-2.5">
              {
                PAINTS.map((p, i) => (
                  <button
                    type="button"
                    data-paint={p.hex}
                    data-paint-label={p.label}
                    aria-label={`Paint: ${p.label}`}
                    aria-pressed={i === 0 ? 'true' : 'false'}
                    class="paint-chip pressable h-9 w-9 border-2 border-line transition-[transform,border-color] duration-200 hover:scale-110 aria-pressed:border-accent"
                    style={`background:${p.hex}`}
                  />
                ))
              }
            </div>
          </div>

          <!-- TINT panel -->
          <div id="tint-panel" class="mt-4 border border-line bg-coal p-6">
            <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-smoke">2 · Select coverage</p>
            <p class="mt-1 text-xs text-smoke/70">Tap the glass areas you want tinted.</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {
                TINT_ZONES.map((z) => (
                  <button
                    type="button"
                    data-tint-zone={z.id}
                    aria-pressed={z.id === 'front-side' || z.id === 'rear-side' ? 'true' : 'false'}
                    class="zone-chip pressable border border-line px-3.5 py-2 text-xs font-bold text-paper transition-colors duration-200 hover:border-smoke/60 aria-pressed:border-accent aria-pressed:bg-accent aria-pressed:text-ink"
                  >
                    {z.label}
                  </button>
                ))
              }
            </div>

            <p class="mt-7 text-[11px] font-bold uppercase tracking-[0.16em] text-smoke">3 · Select your tint</p>
            <div class="mt-3 grid grid-cols-4 gap-2" role="radiogroup" aria-label="Tint shade">
              {
                SHADES.map((s) => (
                  <button
                    type="button" role="radio"
                    aria-checked={s.id === 'dark' ? 'true' : 'false'}
                    data-shade={s.id} data-shade-label={s.label} data-op={s.op}
                    class="shade-chip pressable group border border-line p-2 text-center transition-colors duration-200 hover:border-smoke/60 aria-checked:border-accent"
                  >
                    <span
                      class="block h-8 w-full border border-line/60"
                      style={`background: linear-gradient(rgba(11,21,36,${s.op}), rgba(11,21,36,${s.op})), linear-gradient(135deg, #E8F1F8 0%, #BFD3E2 60%, #DCE9F4 100%)`}
                      aria-hidden="true"
                    />
                    <span class="mt-1.5 block text-xs font-bold text-paper">{s.label}</span>
                    <span class="block text-[10px] text-smoke">{s.vlt}</span>
                  </button>
                ))
              }
            </div>
            <p class="mt-2 text-[11px] leading-relaxed text-smoke/70">
              Tennessee requires 35%+ VLT on front side windows.
            </p>

            <p class="mt-7 text-[11px] font-bold uppercase tracking-[0.16em] text-smoke">4 · What matters most?</p>
            <p class="mt-1 text-xs text-smoke/70">
              Prioritize these benefits so we can match the right 3M film for you.
            </p>
            <div class="mt-3 flex flex-wrap gap-2">
              {
                PRIORITIES.map((p) => (
                  <button
                    type="button"
                    data-priority={p.id}
                    aria-pressed="false"
                    class="prio-chip pressable border border-line px-3.5 py-2 text-xs font-bold text-paper transition-colors duration-200 hover:border-smoke/60 aria-pressed:border-accent aria-pressed:bg-accent aria-pressed:text-ink"
                  >
                    {p.label}
                  </button>
                ))
              }
            </div>
          </div>

          <!-- PPF panel -->
          <div id="ppf-panel" class="mt-4 hidden border border-line bg-coal p-6">
            <p class="text-[11px] font-bold uppercase tracking-[0.16em] text-smoke">2 · Select coverage</p>
            <p class="mt-1 text-xs text-smoke/70">
              Pick individual zones or full coverage for the whole car.
            </p>
            <div class="mt-3 grid grid-cols-2 gap-2">
              {
                PPF_ZONES.map((z) => (
                  <button
                    type="button"
                    data-ppf-zone={z.id}
                    aria-pressed={['bumper-front', 'hood-full', 'fenders-partial', 'mirrors'].includes(z.id) ? 'true' : 'false'}
                    class:list={[
                      'zone-chip pressable border border-line px-3 py-2 text-left text-xs font-bold text-paper transition-colors duration-200 hover:border-smoke/60 aria-pressed:border-accent aria-pressed:bg-accent aria-pressed:text-ink',
                      z.id === 'full' ? 'col-span-2 text-center' : '',
                    ]}
                  >
                    {z.label}
                  </button>
                ))
              }
            </div>

            <p class="mt-7 text-[11px] font-bold uppercase tracking-[0.16em] text-smoke">3 · Select the finish</p>
            <div class="mt-3 grid grid-cols-3 gap-2" role="radiogroup" aria-label="PPF finish">
              {
                FINISHES.map((f) => (
                  <button
                    type="button" role="radio"
                    aria-checked={f.id === 'gloss' ? 'true' : 'false'}
                    data-finish={f.id} data-finish-label={f.label} data-note={f.note}
                    class="finish-chip pressable border border-line px-2 py-2.5 text-center text-xs font-bold text-paper transition-colors duration-200 hover:border-smoke/60 aria-checked:border-accent aria-checked:bg-accent aria-checked:text-ink"
                  >
                    {f.label}
                  </button>
                ))
              }
            </div>
            <p id="finish-note" class="mt-2 text-[11px] leading-relaxed text-smoke/70">{FINISHES[0].note}</p>
          </div>

          <!-- CTA -->
          <a
            id="visualizer-cta"
            href={`https://wa.me/${WHATSAPP_NUMBER}`}
            target="_blank"
            rel="noopener noreferrer"
            class="pressable sticker mt-5 block bg-accent px-8 py-4 text-center text-xs font-bold uppercase tracking-[0.12em] text-ink transition-[background-color,transform] duration-200 hover:-translate-y-0.5 hover:bg-accentDk"
          >
            Contact Your Installer →
          </a>
          <p class="mt-2.5 text-center text-[11px] text-smoke/70">
            Opens WhatsApp with your build pre-filled — we reply with a free quote.
          </p>
        </div>
      </div>
    </section>

    <QuoteCTA />
  </main>
  <Footer />
  <CallFab />

  <!-- Per-vehicle geometry, consumed by the client script -->
  <script type="application/json" id="vehicles-json" is:inline set:html={JSON.stringify(Object.fromEntries(VEHICLES.map((v) => [v.id, v.inner])))}></script>

  <style>
    /* Paint color transitions smoothly between swatches. */
    @property --paint {
      syntax: '<color>';
      inherits: true;
      initial-value: #1a1c20;
    }
    #car-svg {
      --paint: #1a1c20;
      --shade-op: 0.85;
    }
    #car-svg :global(.body-fill) {
      fill: var(--paint);
      transition: fill 350ms var(--ease-out), --paint 350ms var(--ease-out);
    }
    #car-svg :global(.body-shine) {
      transition: opacity 300ms var(--ease-out);
    }
    /* Stealth black restyles the paint; matte kills the gloss highlight. */
    [data-finish='black'][data-mode='ppf'] #car-svg :global(.body-fill) {
      fill: #16181c;
    }
    [data-finish='matte'][data-mode='ppf'] #car-svg :global(.body-shine),
    [data-finish='black'][data-mode='ppf'] #car-svg :global(.body-shine) {
      opacity: 0.22;
    }

    /* Glass: quiet by default, selected zones take the shade opacity. */
    #car-svg :global(.gz) {
      fill: #0b1524;
      opacity: 0.16;
      transition: opacity 300ms var(--ease-out);
    }
    #car-svg :global(.gz.on) {
      opacity: var(--shade-op);
    }
    [data-mode='ppf'] #car-svg :global(.gz) {
      opacity: 0.3;
    }

    /* PPF overlays: draw in with a dash sweep + fade. */
    #car-svg :global(.pz) {
      fill: #00a8ff;
      fill-opacity: 0;
      stroke: #00a8ff;
      stroke-width: 2;
      stroke-dasharray: 6 5;
      opacity: 0;
      transition: opacity 250ms var(--ease-out), fill-opacity 250ms var(--ease-out);
      pointer-events: none;
    }
    [data-mode='ppf'] #car-svg :global(.pz.on) {
      opacity: 1;
      fill-opacity: 0.32;
    }
    [data-finish='matte'] #car-svg :global(.pz) {
      fill: #9fb6c4;
      stroke: #9fb6c4;
    }
    [data-finish='black'] #car-svg :global(.pz) {
      fill: #101216;
      stroke: #3a3f46;
    }
    [data-finish='black'] #car-svg :global(.pz.on) {
      fill-opacity: 0.85;
    }

    /* Vehicle swap: blur-crossfade (blur masks the geometry jump). */
    #car-root {
      transition: opacity 160ms var(--ease-out), filter 160ms var(--ease-out), transform 160ms var(--ease-out);
    }
    #car-root.swapping {
      opacity: 0;
      filter: blur(6px);
      transform: translateX(-10px);
    }

    /* Mini silhouettes in the vehicle picker. */
    .veh-chip svg :global(.body-fill) {
      fill: #6b7280;
      transition: fill 200ms var(--ease-out);
    }
    .veh-chip[aria-checked='true'] svg :global(.body-fill) {
      fill: #00a8ff;
    }
    .veh-chip svg :global(.gz),
    .veh-chip svg :global(.pz),
    .veh-chip svg :global(.body-shine),
    .veh-chip svg :global(ellipse) {
      display: none;
    }

    @media (prefers-reduced-motion: reduce) {
      #car-root,
      #car-svg :global(.gz),
      #car-svg :global(.pz),
      #car-svg :global(.body-fill) {
        transition: none !important;
      }
    }
  </style>

  <script>
    // ══ Visualizer state ═════════════════════════════════════════════
    const vehicles: Record<string, string> = JSON.parse(
      document.getElementById('vehicles-json')!.textContent!
    );

    const state = {
      mode: 'tint' as 'tint' | 'ppf',
      vehicle: 'sedan',
      vehicleLabel: 'Sedan',
      paint: '#1A1C20',
      paintLabel: 'Black',
      tintZones: new Set(['front-side', 'rear-side']),
      shade: 'dark',
      shadeLabel: 'Dark',
      shadeOp: 0.85,
      priorities: new Set<string>(),
      ppfZones: new Set(['bumper-front', 'hood-full', 'fenders-partial', 'mirrors']),
      finish: 'gloss',
      finishLabel: 'Gloss',
    };

    const SHADE_META: Record<string, { label: string; vlt: string; frontLegal: boolean }> = {
      dark: { label: 'Dark', vlt: '5–35% VLT', frontLegal: false },
      medium: { label: 'Medium', vlt: '35–65% VLT', frontLegal: true },
      light: { label: 'Light', vlt: '65–95% VLT', frontLegal: true },
      clear: { label: 'Clear', vlt: '95–100% VLT', frontLegal: true },
    };
    const ZONE_LABELS: Record<string, string> = {};
    document.querySelectorAll<HTMLElement>('[data-tint-zone],[data-ppf-zone]').forEach((b) => {
      ZONE_LABELS[b.dataset.tintZone || b.dataset.ppfZone!] = b.textContent!.trim();
    });

    const root = document.getElementById('visualizer')!;
    const carSvg = document.getElementById('car-svg')!;
    const carRoot = document.getElementById('car-root')!;
    const summary = document.getElementById('build-summary')!;
    const badge = document.getElementById('legal-badge')!;
    const cta = document.getElementById('visualizer-cta') as HTMLAnchorElement;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ══ Render ═══════════════════════════════════════════════════════
    function applyZones() {
      const glassSel = state.tintZones;
      carRoot.querySelectorAll<SVGElement>('.gz').forEach((el) => {
        el.classList.toggle('on', glassSel.has(el.dataset.z!));
      });
      const full = state.ppfZones.has('full');
      carRoot.querySelectorAll<SVGElement>('.pz').forEach((el) => {
        const z = el.dataset.z!;
        el.classList.toggle('on', full ? z === 'full' : state.ppfZones.has(z));
      });
    }

    function render() {
      root.dataset.mode = state.mode;
      root.dataset.finish = state.finish;
      carSvg.style.setProperty('--paint', state.paint);
      carSvg.style.setProperty('--shade-op', String(state.shadeOp));
      applyZones();

      // Summary line
      if (state.mode === 'tint') {
        const zones = [...state.tintZones].map((z) => ZONE_LABELS[z]).join(', ') || 'no zones yet';
        summary.textContent = `${state.vehicleLabel} · ${state.shadeLabel} (${SHADE_META[state.shade].vlt}) · ${zones}`;
      } else {
        const zones = state.ppfZones.has('full')
          ? 'Full coverage'
          : [...state.ppfZones].map((z) => ZONE_LABELS[z]).join(', ') || 'no zones yet';
        summary.textContent = `${state.vehicleLabel} · ${state.finishLabel} PPF · ${zones}`;
      }

      // Legal badge (tint mode only)
      const frontTinted = state.tintZones.has('front-side');
      const legal = !frontTinted || SHADE_META[state.shade].frontLegal;
      badge.style.display = state.mode === 'tint' ? '' : 'none';
      badge.textContent = legal ? 'TN legal · selected zones' : 'TN: 35%+ required on front sides';
      badge.className = legal
        ? 'shrink-0 bg-accent/15 px-3 py-1.5 text-[10px] font-bold uppercase tracking-[0.12em] text-accent'
        : 'shrink-0 bg-[#3A2A00] px-3 py-1.5 text-[10px] font-bold uppercase tracking-[0.12em] text-[#FFB020]';

      // WhatsApp CTA
      let msg: string;
      if (state.mode === 'tint') {
        const zones = [...state.tintZones].map((z) => ZONE_LABELS[z]).join(', ') || 'to be decided';
        const prio = [...state.priorities].map((p) => ZONE_LABELS[p] ?? p).join(', ');
        msg =
          `Hi! I built this in your film visualizer — Window tint on a ${state.vehicleLabel.toLowerCase()}` +
          ` (${state.paintLabel.toLowerCase()}). Zones: ${zones}. Shade: ${state.shadeLabel} (${SHADE_META[state.shade].vlt}).` +
          (prio ? ` Priorities: ${prio}.` : '') +
          ` Can I get a quote?`;
      } else {
        const zones = state.ppfZones.has('full')
          ? 'full coverage'
          : [...state.ppfZones].map((z) => ZONE_LABELS[z]).join(', ') || 'to be decided';
        msg =
          `Hi! I built this in your film visualizer — Paint protection film on a ${state.vehicleLabel.toLowerCase()}` +
          ` (${state.paintLabel.toLowerCase()}). Coverage: ${zones}. Finish: ${state.finishLabel}. Can I get a quote?`;
      }
      cta.href = `${cta.href.split('?')[0]}?text=${encodeURIComponent(msg)}`;
    }

    // ══ Vehicle switching (blur-crossfade) ═══════════════════════════
    let swapping = false;
    function swapVehicle(id: string, label: string) {
      if (swapping || state.vehicle === id) return;
      state.vehicle = id;
      state.vehicleLabel = label;
      const doSwap = () => {
        carRoot.innerHTML = vehicles[id];
        applyZones();
        render();
      };
      if (reduceMotion) return doSwap();
      swapping = true;
      carRoot.classList.add('swapping');
      setTimeout(() => {
        doSwap();
        requestAnimationFrame(() =>
          requestAnimationFrame(() => {
            carRoot.classList.remove('swapping');
            swapping = false;
          })
        );
      }, 170);
    }

    // ══ Wiring ═══════════════════════════════════════════════════════
    const $$ = (sel: string) => Array.from(document.querySelectorAll<HTMLElement>(sel));

    $$('.veh-chip').forEach((chip) =>
      chip.addEventListener('click', () => {
        $$('.veh-chip').forEach((c) => {
          const on = c === chip;
          c.setAttribute('aria-checked', String(on));
          c.classList.toggle('border-accent', on);
          c.classList.toggle('bg-accent/10', on);
          c.classList.toggle('border-line', !on);
        });
        swapVehicle(chip.dataset.vehicle!, chip.querySelector('span')!.textContent!.trim());
      })
    );

    $$('.mode-tab').forEach((tab) =>
      tab.addEventListener('click', () => {
        state.mode = tab.dataset.tab as 'tint' | 'ppf';
        $$('.mode-tab').forEach((t) => {
          const on = t === tab;
          t.setAttribute('aria-selected', String(on));
          t.classList.toggle('text-accent', on);
          t.classList.toggle('text-smoke', !on);
          t.querySelector('.tab-line')?.classList.toggle('scale-x-0', !on);
        });
        document.getElementById('tint-panel')!.classList.toggle('hidden', state.mode !== 'tint');
        document.getElementById('ppf-panel')!.classList.toggle('hidden', state.mode !== 'ppf');
        render();
      })
    );

    $$('.paint-chip').forEach((chip) =>
      chip.addEventListener('click', () => {
        state.paint = chip.dataset.paint!;
        state.paintLabel = chip.dataset.paintLabel!;
        $$('.paint-chip').forEach((c) => c.setAttribute('aria-pressed', String(c === chip)));
        render();
      })
    );

    $$('[data-tint-zone]').forEach((chip) =>
      chip.addEventListener('click', () => {
        const z = chip.dataset.tintZone!;
        const on = !state.tintZones.has(z);
        state.tintZones[on ? 'add' : 'delete'](z);
        chip.setAttribute('aria-pressed', String(on));
        render();
      })
    );

    $$('.shade-chip').forEach((chip) =>
      chip.addEventListener('click', () => {
        state.shade = chip.dataset.shade!;
        state.shadeLabel = chip.dataset.shadeLabel!;
        state.shadeOp = Number(chip.dataset.op);
        $$('.shade-chip').forEach((c) => c.setAttribute('aria-checked', String(c === chip)));
        render();
      })
    );

    $$('.prio-chip').forEach((chip) =>
      chip.addEventListener('click', () => {
        const p = chip.dataset.priority!;
        const on = !state.priorities.has(p);
        state.priorities[on ? 'add' : 'delete'](p);
        chip.setAttribute('aria-pressed', String(on));
        ZONE_LABELS[p] = chip.textContent!.trim();
        render();
      })
    );

    // PPF zones: "full" is exclusive; hood/fender variants are mutually exclusive.
    const EXCLUSIVE: Record<string, string> = {
      'hood-full': 'hood-partial',
      'hood-partial': 'hood-full',
      'fenders-full': 'fenders-partial',
      'fenders-partial': 'fenders-full',
    };
    $$('[data-ppf-zone]').forEach((chip) =>
      chip.addEventListener('click', () => {
        const z = chip.dataset.ppfZone!;
        const on = !state.ppfZones.has(z);
        if (z === 'full') {
          state.ppfZones.clear();
          if (on) state.ppfZones.add('full');
        } else {
          state.ppfZones.delete('full');
          if (on && EXCLUSIVE[z]) state.ppfZones.delete(EXCLUSIVE[z]);
          state.ppfZones[on ? 'add' : 'delete'](z);
        }
        $$('[data-ppf-zone]').forEach((c) =>
          c.setAttribute('aria-pressed', String(state.ppfZones.has(c.dataset.ppfZone!)))
        );
        render();
      })
    );

    $$('.finish-chip').forEach((chip) =>
      chip.addEventListener('click', () => {
        state.finish = chip.dataset.finish!;
        state.finishLabel = chip.dataset.finishLabel!;
        document.getElementById('finish-note')!.textContent = chip.dataset.note!;
        $$('.finish-chip').forEach((c) => c.setAttribute('aria-checked', String(c === chip)));
        render();
      })
    );

    document.getElementById('reset-btn')!.addEventListener('click', () => {
      state.tintZones = new Set(['front-side', 'rear-side']);
      state.priorities = new Set();
      state.ppfZones = new Set(['bumper-front', 'hood-full', 'fenders-partial', 'mirrors']);
      state.shade = 'dark';
      state.shadeLabel = 'Dark';
      state.shadeOp = 0.85;
      state.finish = 'gloss';
      state.finishLabel = 'Gloss';
      $$('[data-tint-zone]').forEach((c) =>
        c.setAttribute('aria-pressed', String(state.tintZones.has(c.dataset.tintZone!)))
      );
      $$('[data-ppf-zone]').forEach((c) =>
        c.setAttribute('aria-pressed', String(state.ppfZones.has(c.dataset.ppfZone!)))
      );
      $$('.prio-chip').forEach((c) => c.setAttribute('aria-pressed', 'false'));
      $$('.shade-chip').forEach((c) => c.setAttribute('aria-checked', String(c.dataset.shade === 'dark')));
      $$('.finish-chip').forEach((c) => c.setAttribute('aria-checked', String(c.dataset.finish === 'gloss')));
      render();
    });

    render();
  </script>
</Layout>
